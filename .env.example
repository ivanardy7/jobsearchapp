# OpenAI API configuration
OPENAI_API_KEY=your_openai_api_key_here

# Vector Store configuration (Cloud Qdrant)
QDRANT_URL=your_qdrant_cloud_endpoint_url
QDRANT_API_KEY=your_qdrant_cloud_api_key

# Database configuration (Aiven MySQL)
DATABASE_URL=mysql://username:password@host:port/dbname?ssl-mode=REQUIRED

# N8N Integration
# Set USE_N8N=true setelah import workflow ke N8N dan aktivasi webhook
USE_N8N=false
N8N_WEBHOOK_URL=https://n8n-student.purwadhika.com
